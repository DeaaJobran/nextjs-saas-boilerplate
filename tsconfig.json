{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./apps/web/src/*"],
      "@nextjs-saas/api": ["./packages/api/src/index.ts"],
      "@nextjs-saas/api/*": ["./packages/api/src/*"],
      "@nextjs-saas/auth": ["./packages/auth/src/index.ts"],
      "@nextjs-saas/auth/*": ["./packages/auth/src/*"],
      "@nextjs-saas/billing": ["./packages/billing/src/index.ts"],
      "@nextjs-saas/billing/*": ["./packages/billing/src/*"],
      "@nextjs-saas/config": ["./packages/config/src/index.ts"],
      "@nextjs-saas/config/*": ["./packages/config/src/*"],
      "@nextjs-saas/db": ["./packages/db/src/index.ts"],
      "@nextjs-saas/db/*": ["./packages/db/src/*"],
      "@nextjs-saas/jobs": ["./packages/jobs/src/index.ts"],
      "@nextjs-saas/jobs/*": ["./packages/jobs/src/*"],
      "@nextjs-saas/localization": ["./packages/localization/src/index.ts"],
      "@nextjs-saas/localization/*": ["./packages/localization/src/*"],
      "@nextjs-saas/tenant": ["./packages/tenant/src/index.ts"],
      "@nextjs-saas/tenant/*": ["./packages/tenant/src/*"],
      "@nextjs-saas/ui": ["./packages/ui/src/index.ts"],
      "@nextjs-saas/ui/*": ["./packages/ui/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
