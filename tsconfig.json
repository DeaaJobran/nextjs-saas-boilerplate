{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./apps/web/src/*"],
      "@nextjs-saas/config": ["./packages/config/src/index.ts"],
      "@nextjs-saas/config/*": ["./packages/config/src/*"],
      "@nextjs-saas/localization": ["./packages/localization/src/index.ts"],
      "@nextjs-saas/localization/*": ["./packages/localization/src/*"],
      "@nextjs-saas/ui": ["./packages/ui/src/index.ts"],
      "@nextjs-saas/ui/*": ["./packages/ui/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
