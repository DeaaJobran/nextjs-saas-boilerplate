{
  "name": "nextjs-saas-boilerplate",
  "version": "0.3.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.12 <27",
    "pnpm": ">=11.7 <12"
  },
  "scripts": {
    "dev": "pnpm --filter @nextjs-saas/web dev",
    "build": "pnpm -r --if-present build",
    "start": "pnpm --filter @nextjs-saas/web start",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "i18n:check": "node scripts/validate-translations.mjs",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "playwright:install": "playwright install chromium",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:a11y": "playwright test --config=playwright.a11y.config.ts",
    "doctor:react": "react-doctor",
    "validate": "git diff --check && pnpm format:check && pnpm lint && pnpm i18n:check && pnpm typecheck && pnpm test && pnpm build && pnpm build:storybook && pnpm playwright:install && pnpm test:e2e && pnpm test:a11y",
    "ci:checks": "pnpm validate",
    "commit": "cz",
    "db:generate": "pnpm --filter @nextjs-saas/db generate",
    "db:migrate": "pnpm --filter @nextjs-saas/db migrate",
    "db:reset": "pnpm --filter @nextjs-saas/db reset",
    "db:seed": "pnpm --filter @nextjs-saas/db seed",
    "jobs:worker": "pnpm --filter @nextjs-saas/jobs worker",
    "services:down": "docker compose down",
    "services:logs": "docker compose logs -f",
    "services:up": "docker compose up -d",
    "prepare": "husky"
  },
  "dependencies": {},
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-vitest": "^10.5.0",
    "@storybook/nextjs-vite": "^10.5.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "commitizen": "^4.3.2",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react-doctor": "^0.7.1",
    "storybook": "^10.5.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,mdx,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
